# ── Restaurant Management System — environment configuration ──
# Copy this file to ".env" and fill in real values.

# Server
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000

# Authentication (REQUIRED — server refuses to start with the weak default)
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h

# Bill settlement
# Sales tax applied to bills at checkout (0.08 = 8%)
SALES_TAX_RATE=0.08

# ── Stripe (optional) ──────────────────────────────────────────
# Leave BOTH blank to run payments in simulated "record-only" mode
# (no real charge — totals, tips and payroll all still work).
#
# To enable a REAL test-card flow:
#   1. Create a free account at https://dashboard.stripe.com
#   2. Make sure you are in TEST mode (toggle, top-right).
#   3. Developers → API keys → copy the two test keys below.
#   4. Restart the server (npm start).
#   5. At checkout choose "Card" and use Stripe's test card:
#        4242 4242 4242 4242   any future expiry   any CVC   any ZIP
#
# Test keys start with sk_test_ / pk_test_ (never commit real keys).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── Email (optional) ───────────────────────────────────────────
# Leave SMTP_* blank to run email in simulated mode: reservation
# confirmations, receipts, and password-reset links are written to the
# email_log table (and console) but not actually sent. Fill these in to
# send real email through any SMTP provider (e.g. Gmail, SendGrid, Mailgun).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Restaurant <no-reply@restaurant.local>

# ── SMS notifications (optional) ───────────────────────────────
# Guests are texted on order received / payment / ready-for-pickup /
# delivery on-the-way+delivered / reservation request (when a phone is on file).
# Pick a provider; unset or "auto" → Twilio if configured, else simulated.
# Simulated mode records to the sms_log table (nothing is actually sent).
#   simulated | twilio | textbelt | email_gateway
SMS_PROVIDER=simulated

# Twilio — paid (free trial credit). FROM in E.164, e.g. +15551234567
# Requires the 'twilio' npm package (npm i twilio).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# TextBelt — FREE: 1 text/day with the default key; self-host TEXTBELT_URL for unlimited.
# Set SMS_PROVIDER=textbelt to use it.
TEXTBELT_KEY=textbelt
# TEXTBELT_URL=https://textbelt.com/text

# Email-to-SMS carrier gateway — FREE; reuses the SMTP settings above (configure those too).
# Set SMS_PROVIDER=email_gateway and the recipient carrier's gateway domain (US examples):
#   Verizon vtext.com · AT&T txt.att.net · T-Mobile tmomail.net
SMS_EMAIL_GATEWAY=
