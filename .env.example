# ── Restaurant Management System — environment configuration ──
# Copy this file to ".env" and fill in real values.

# Server
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000

# Authentication (REQUIRED — server refuses to start with the weak default)
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=8h

# Bill settlement
# Sales tax applied to bills at checkout (0.08 = 8%)
SALES_TAX_RATE=0.08

# ── Stripe (optional) ──────────────────────────────────────────
# Leave BOTH blank to run payments in simulated "record-only" mode
# (no real charge — totals, tips and payroll all still work).
#
# To enable a REAL test-card flow:
#   1. Create a free account at https://dashboard.stripe.com
#   2. Make sure you are in TEST mode (toggle, top-right).
#   3. Developers → API keys → copy the two test keys below.
#   4. Restart the server (npm start).
#   5. At checkout choose "Card" and use Stripe's test card:
#        4242 4242 4242 4242   any future expiry   any CVC   any ZIP
#
# Test keys start with sk_test_ / pk_test_ (never commit real keys).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
